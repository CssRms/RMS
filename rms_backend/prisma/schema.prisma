// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int             @id @default(autoincrement())
  email                String          @unique
  name                 String
  password             String
  role                 String          @default("staff")
  mfaEnabled           Boolean         @default(false)
  mfaSecret            String?
  departmentId         Int?
  department           Department?     @relation(fields: [departmentId], references: [id])
  requisitions         Requisition[]   @relation("RequisitionCreator")
  actionedRequisitions Requisition[]   @relation("RequisitionLastAction")
  memos                Memo[]
  activityLogs         ActivityLog[]
  notifications        Notification[]
  fileAccessLogs       FileAccessLog[]
  approvals            Approval[]
  signature            UserSignature?
  uploadedAttachments  Attachment[]    @relation("AttachmentUploader")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Department {
  id              Int              @id @default(autoincrement())
  code            String?          @unique // Optional short code
  name            String           @unique
  type            String           @default("Operational") // "Strategic", "Operational"
  accessCode          String? // Legacy plain access code (deprecated)
  accessCodeHash      String? // Bcrypt hash for departmental login
  accessCodeLabel     String? // Admin-visible login code label (original as set by admin)
  codeChangedByDept   Boolean @default(false) // True when dept self-changed their code
  headName        String?
  headTitle       String?
  headEmail       String?
  phone           String?
  address         String?
  parentId        Int?
  parent          Department?      @relation("Hierarchy", fields: [parentId], references: [id])
  subDepartments  Department[]     @relation("Hierarchy")
  isSubAccount    Boolean          @default(false)
  createdByDeptId Int?
  isDisabled      Boolean          @default(false)
  isDeleted       Boolean          @default(false)
  users           User[]
  requisitions    Requisition[]
  memos           Memo[]
  stamp           DepartmentStamp?
  signingKeys          DepartmentKey[]
  notifications        Notification[]
  sentMessages         ChatMessage[]    @relation("ChatSender")
  receivedMessages     ChatMessage[]    @relation("ChatRecipient")
  targetedRequisitions Requisition[]    @relation("RequisitionTarget")
  forwardEventsFrom    ForwardEvent[]   @relation("ForwardFrom")
  forwardEventsTo      ForwardEvent[]   @relation("ForwardTo")
  finalApprovedRequisitions Requisition[] @relation("FinalApprover")
  treatedRequisitions       Requisition[] @relation("TreatedBy")
  canPrint             Boolean          @default(true)
  subVisibilities      RequisitionSubVisibility[] @relation("SubVisibility")
  storeRecords         StoreRecord[]
  // Sub-account identity — staff ID is the primary unique identifier per person
  staffId              String?  @unique // Staff ID (e.g. CSS001) — primary identifier, replaces name-based conflict detection
  // Sub-account privilege delegation (set by parent dept head or admin)
  privilegeAmount      Float?   // Max amount sub-account can CREATE a request for
  approvalLimit        Float?   // Max amount of incoming request sub-account can APPROVE on head's behalf
  cashPrivilege        Boolean          @default(false)
  memoPrivilege        Boolean          @default(false)
  materialPrivilege    Boolean          @default(false)
  // Per-sub-account routing: if false, all requests route through parent head first
  directRoute          Boolean          @default(false)
  // JSON array of dept IDs the sub-account may target directly; null = any department
  allowedRouteDeptIds  String?
  // Head dept routing control: if false, sub-account requests land here first before going anywhere
  subAccountAutoRoute  Boolean          @default(true)
  // Batch-upload succession — marks the sub-account designated to inherit the parent
  // department's full approval authority if the head is disabled/deleted. Auto-elevated
  // (privilegeAmount/approvalLimit/directRoute overwritten) the moment that happens;
  // preElevationPrivileges snapshots the prior values so they can be restored if the head
  // is reinstated.
  isActingHeadCandidate Boolean         @default(false)
  preElevationPrivileges String?        @db.Text // JSON: { privilegeAmount, approvalLimit, directRoute, cashPrivilege, memoPrivilege, materialPrivilege }
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

// Per-sub-account visibility: dept head can share a specific request with selected sub-units only
model RequisitionSubVisibility {
  requisitionId Int
  subAccountId  Int
  requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  subAccount    Department  @relation("SubVisibility", fields: [subAccountId], references: [id], onDelete: Cascade)
  @@id([requisitionId, subAccountId])
}

model Requisition {
  id             Int            @id @default(autoincrement())
  clientId       String?        @unique
  title          String
  type           String // "Cash", "Material", "Memo"
  amount         Float?
  description    String?
  urgency        String         @default("normal")
  status         String         @default("pending")
  creatorId      Int
  creator        User           @relation("RequisitionCreator", fields: [creatorId], references: [id])
  departmentId   Int
  department     Department     @relation(fields: [departmentId], references: [id])
  attachments    Attachment[]
  approvals      Approval[]
  forwardEvents  ForwardEvent[]
  content        String?        @db.Text
  currentStageId Int?
  currentStage   WorkflowStage? @relation(fields: [currentStageId], references: [id])
  approvedAt     DateTime?
  rejectedAt     DateTime?
  lastActionById Int?
  lastActionBy   User?          @relation("RequisitionLastAction", fields: [lastActionById], references: [id])
  lastActionAt   DateTime?
  signedPdfKey       String?
  signedPdfHash      String?
  targetDepartmentId Int?
  targetDepartment   Department? @relation("RequisitionTarget", fields: [targetDepartmentId], references: [id])
  forwardNote        String?
  
  // Final Approval & Vetting Workflow
  finalApprovalStatus   String?        @default("none")
  finalApprovedByDeptId  Int?
  finalApprovedByDept   Department? @relation("FinalApprover", fields: [finalApprovedByDeptId], references: [id])
  finalApprovedAt       DateTime?
  finalApprovedNote     String?
  currentVettingDeptId  Int?
  treatedByDeptId       Int?
  treatedByDept         Department?    @relation("TreatedBy", fields: [treatedByDeptId], references: [id])
  treatedAt             DateTime?
  amountDisbursed       Float?
  treatmentType         String?
  treatmentReason       String?
  vettingEvents         VettingEvent[]
  tags                  RequisitionTag[]

  publishStartAt     DateTime?
  publishEndAt       DateTime?

  // KIV (Keep In View) — holder puts request on hold without forwarding or rejecting
  isKIV      Boolean   @default(false)
  kivNote    String?   @db.Text
  kivAt      DateTime?
  kivByName  String?

  // Sub-account visibility — dept head can share with all or selected sub-units
  visibleToSubAccounts Boolean @default(false)
  subVisibilities      RequisitionSubVisibility[]

  // Sub-account privilege delegation (set by parent dept head or Super Admin):
  //   privilegeAmount — max cash (₦) this sub-account can CREATE (creator depts)
  //                     OR see/act on incoming requests (threshold depts: HR/Audit/Account)
  //   memoPrivilege   — toggle: sub-account can create & fully handle memo requests
  //   materialPrivilege — toggle: sub-account can create & fully handle material requests
  privilegeAmount   Float?
  memoPrivilege     Boolean @default(false)
  materialPrivilege Boolean @default(false)

  // ICC Global Observer — freeze blocks ALL actions on the request until lifted
  iccFrozen     Boolean   @default(false)
  iccFreezeNote String?   @db.Text
  iccFreezeAt   DateTime?
  iccFreezeBy   String?

  // Auto-generated reference code: CSSG/ISAC/FR/24032026/01
  refCode   String?

  // Audit / Vetting Price Override — vetting dept can supply their own verified items table
  // which supersedes the creator's estimate for threshold decisions and payment
  hasAuditOverride  Boolean  @default(false)
  auditContent      String?  @db.Text   // JSON: { itemized, items, comment, total }
  auditAmount       Float?              // verified total from audit dept
  auditDeptId       Int?
  auditDeptName     String?

  // ICC Vets Protocol — mandatory gate between Account/CEO-Chairman receiving a
  // Cash/Material request and treating it. The holder must forward to ICC; ICC vets it
  // (and may override the price table for Cash only) before returning it to whichever
  // department forwarded it (tracked via iccForwardedFromDeptId).
  // iccVettingCleared stays false until ICC returns it — holder cannot treat until then.
  iccVettingCleared      Boolean   @default(false)
  iccVettingNote         String?   @db.Text
  iccVettingAt           DateTime?
  iccVettingByDeptId     Int?
  iccForwardedFromDeptId Int?
  hasIccOverride         Boolean   @default(false)
  iccOverrideContent     String?   @db.Text   // JSON: { itemized, items, comment, total }
  iccOverrideAmount      Float?               // verified total from ICC — takes priority over Audit's
  iccOverrideDeptName    String?

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model VettingEvent {
  id              Int         @id @default(autoincrement())
  requisitionId   Int
  requisition     Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  deptId          Int
  deptName        String?
  action          String
  vetted          Boolean     @default(false)
  comment         String?     @db.Text
  attachmentKey   String?
  attachmentName  String?
  actorName       String?
  amountDisbursed Float?
  treatmentType   String?
  treatmentReason String?
  createdAt       DateTime    @default(now())
}

model ForwardEvent {
  id              Int          @id @default(autoincrement())
  requisitionId   Int
  requisition     Requisition  @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  fromDeptId      Int
  fromDepartment  Department   @relation("ForwardFrom", fields: [fromDeptId], references: [id])
  toDeptId        Int?
  toDepartment    Department?  @relation("ForwardTo", fields: [toDeptId], references: [id])
  action          String       // "created" | "forwarded" | "returned"
  note            String?      @db.Text
  actorName       String?
  createdAt       DateTime     @default(now())
}

model Memo {
  id           Int        @id @default(autoincrement())
  title        String
  content      String     @db.Text
  status       String     @default("draft") // "draft", "published", "archived"
  creatorId    Int
  creator      User       @relation(fields: [creatorId], references: [id])
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  timestamp DateTime @default(now())
}

model RequisitionType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model WorkflowStage {
  id           Int           @id @default(autoincrement())
  sequence     Int           @unique
  name         String
  role         String
  threshold    Float         @default(0)
  requisitions Requisition[]
  approvals    Approval[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Notification {
  id           Int         @id @default(autoincrement())
  userId       Int?
  user         User?       @relation(fields: [userId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  content      String
  link         String?
  isRead       Boolean     @default(false)
  createdAt    DateTime    @default(now())
}

model Attachment {
  id            Int             @id @default(autoincrement())
  filename      String
  path          String?
  fileType      String?
  storageKey    String?
  mimeType      String?
  size          Int?
  stageName     String?         // Human-readable stage label at time of upload
  stageKey      String?         // Machine key matching PrintStageModal stage IDs (e.g. fwd-5, app-3, submission)
  uploaderDept  String?         // Department name of uploader at time of upload
  requisitionId Int?
  requisition   Requisition?    @relation(fields: [requisitionId], references: [id])
  uploadedById  Int?
  uploadedBy    User?           @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  accessLogs    FileAccessLog[]
  createdAt     DateTime        @default(now())
}

model FileAccessLog {
  id           Int        @id @default(autoincrement())
  attachmentId Int
  attachment   Attachment @relation(fields: [attachmentId], references: [id])
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  action       String     @default("VIEW")
  timestamp    DateTime   @default(now())
}

model Approval {
  id            Int              @id @default(autoincrement())
  requisitionId Int
  requisition   Requisition      @relation(fields: [requisitionId], references: [id])
  stageId       Int
  stage         WorkflowStage    @relation(fields: [stageId], references: [id])
  action        String // "approved" | "rejected"
  remarks       String?
  userId        Int
  user          User             @relation(fields: [userId], references: [id])
  signature     SignatureRecord?
  createdAt     DateTime         @default(now())
}

model SignatureRecord {
  id               Int       @id @default(autoincrement())
  approvalId       Int       @unique
  approval         Approval  @relation(fields: [approvalId], references: [id])
  payloadHash      String
  signature        String
  verificationCode String    @unique
  publicKeyId      Int
  publicKey        PublicKey @relation("SignatureRecordPublicKey", fields: [publicKeyId], references: [id])
  createdAt        DateTime  @default(now())
}

model DepartmentStamp {
  id           Int        @id @default(autoincrement())
  departmentId Int        @unique
  department   Department @relation(fields: [departmentId], references: [id])
  imageKey     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model UserSignature {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  imageKey  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublicKey {
  id               Int               @id @default(autoincrement())
  kid              String            @unique
  algorithm        String
  publicKey        String
  active           Boolean           @default(true)
  signatureRecords SignatureRecord[] @relation("SignatureRecordPublicKey")
  departmentKeys   DepartmentKey[]   @relation("DepartmentKeyPublicKey")
  createdAt        DateTime          @default(now())
}

model DepartmentKey {
  id            Int        @id @default(autoincrement())
  departmentId  Int        @unique
  department    Department @relation(fields: [departmentId], references: [id])
  publicKeyId   Int
  publicKey     PublicKey  @relation("DepartmentKeyPublicKey", fields: [publicKeyId], references: [id])
  privateKeyEnc String
  algorithm     String     @default("Ed25519")
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model SystemSetting {
  key   String @id
  value String @default("")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  deptId    Int?
  userId    Int?
  createdAt DateTime @default(now())
}

model RequisitionTag {
  id             Int         @id @default(autoincrement())
  requisitionId  Int
  requisition    Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  deptId         Int
  taggedByDeptId Int?
  taggedAt       DateTime    @default(now())

  @@unique([requisitionId, deptId])
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  fromDeptId  Int
  fromDept    Department  @relation("ChatSender", fields: [fromDeptId], references: [id])
  toDeptId    Int?        // null = group broadcast
  toDept      Department? @relation("ChatRecipient", fields: [toDeptId], references: [id])
  body        String      @default("") @db.Text
  readBy      Int[]       // deptIds that have opened/read this message
  mediaKey    String?     // S3 key for attached media
  mediaType   String?     // "audio" | "image" | "file"
  mediaName   String?     // original filename
  mediaMime   String?     // MIME type
  replyToId   Int?
  replyTo     ChatMessage?  @relation("ChatReplies", fields: [replyToId], references: [id])
  replies     ChatMessage[] @relation("ChatReplies")
  editedAt    DateTime?
  reqRef      String?       @db.Text
  createdAt   DateTime    @default(now())
}

// ── Store Records — stock ledger for Store department and its sub-accounts ──
model StoreRecord {
  id             Int                @id @default(autoincrement())
  code           String
  description    String
  location       String?
  carriedForward Float              @default(0)
  departmentId   Int
  department     Department         @relation(fields: [departmentId], references: [id])
  entries        StoreRecordEntry[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model StoreRecordEntry {
  id                Int         @id @default(autoincrement())
  storeRecordId     Int
  storeRecord       StoreRecord @relation(fields: [storeRecordId], references: [id], onDelete: Cascade)
  sequence          Int
  date              String?
  openingBalance    Float       @default(0)
  qtyReceived       Float       @default(0)
  quantityIssued    Float       @default(0)
  requisitionSlipNo String?
  stockBalance      Float       @default(0)
  materialsTaken    String?
  remarks           String?
  createdAt         DateTime    @default(now())
}

model DeletedRecord {
  id             Int      @id @default(autoincrement())
  originalId     Int
  recordType     String
  title          String?
  departmentId   Int?
  departmentName String?
  deletedByName  String?
  deletedAt      DateTime @default(now())
  snapshot       Json
}
